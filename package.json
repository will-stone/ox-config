{
  "name": "ox-config",
  "private": true,
  "description": "My configs for Oxc tooling",
  "homepage": "https://github.com/will-stone/ox-config#readme",
  "bugs": {
    "url": "https://github.com/will-stone/ox-config/issues"
  },
  "license": "MIT",
  "author": "Will Stone",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/will-stone/ox-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint",
    "build": "pnpm run build --if-present",
    "prepare": "husky",
    "oxlint-inspector": "node ./oxlint-rule-checker/oxlint-rule-checker.ts",
    "test": "vitest"
  },
  "dependencies": {
    "es-toolkit": "^1.47.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.1",
    "vitest": "^4.1.7"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.1"
    },
    "runtime": {
      "name": "node",
      "version": "24"
    }
  }
}
