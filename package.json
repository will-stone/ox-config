{
  "name": "ox-config",
  "private": true,
  "description": "My configs for Oxc tooling",
  "homepage": "https://github.com/will-stone/ox-config#readme",
  "bugs": {
    "url": "https://github.com/will-stone/ox-config/issues"
  },
  "license": "MIT",
  "author": "Will Stone",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/will-stone/ox-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint",
    "build": "pnpm -r run build",
    "prepare": "husky",
    "oxlint-rule-checker": "node ./oxlint-rule-checker/oxlint-rule-checker.ts",
    "test": "vitest"
  },
  "dependencies": {
    "es-toolkit": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "husky": "catalog:",
    "nano-staged": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.1"
    },
    "runtime": {
      "name": "node",
      "version": "24"
    }
  }
}
